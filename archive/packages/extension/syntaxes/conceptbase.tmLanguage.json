{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ConceptBase",
  "scopeName": "source.conceptbase",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.conceptbase",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.conceptbase",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.conceptbase", "match": "\\\\." }]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conceptbase",
          "match": "\\b(frame|end|in|isa|assertion|rule|forall|exists|and|or|not|==>|select|derive)\\b"
        }
      ]
    }
  }
}
